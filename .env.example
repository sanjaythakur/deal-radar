# Crustdata API key (https://docs.crustdata.com)
CRUSTDATA_API_KEY=

# OpenAI API key (https://platform.openai.com)
OPENAI_API_KEY=

# OpenAI model — default is the value-for-money pick.
# Bump to gpt-5.4 for higher-quality outreach copy.
OPENAI_MODEL=gpt-5.4-mini

# Postgres connection string. The bundled docker-compose `db` service uses:
#   postgres://dealradar:dealradar@db:5432/dealradar  (inside compose network)
# For a local Postgres reachable from `npm run dev`:
#   postgres://dealradar:dealradar@localhost:5432/dealradar
DATABASE_URL=postgres://dealradar:dealradar@localhost:5432/dealradar
